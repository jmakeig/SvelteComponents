{
	"name": "ComboBox",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/SvelteComponents",
	"features": {
		"ghcr.io/devcontainers/features/node:2.1.0": {
			"version": "lts"
		}
	},
	"forwardPorts": [5173, 5432],
	"containerEnv": {
		"DATABASE_URL": "postgresql://postgres:postgres@db:5432/combobox"
	},
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y postgresql-client && npm install -g npm@latest && npm install -g @anthropic-ai/claude-code && npm install",
	"customizations": {
		"vscode": {
			"extensions": [
				"esbenp.prettier-vscode",
				"svelte.svelte-vscode",
				"dracula-theme.theme-dracula",
				"editorconfig.editorconfig",
				"anthropic.claude-code",
				"statelyai.stately-vscode",
				"MylesMurphy.prettify-ts"
			],
			"settings": {
				"remote.autoForwardPorts": false,
				"workbench.colorTheme": "Dracula",
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				"[svelte]": {
					"editor.defaultFormatter": "svelte.svelte-vscode"
				},
				"editor.minimap.enabled": false,
				"scm.diffDecorations": "gutter"
			}
		}
	}
}
